{
  "IsEncrypted": false,
  "Values": {
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",

    "AzureWebJobsStorage": "UseDevelopmentStorage=true",

    "APPLICATIONINSIGHTS_CONNECTION_STRING": "<from: Azure Portal → Application Insights → energytracker-insights → Connection String>",

    "SqlConnectionString": "Server=tcp:<SQL_SERVER_FQDN>,1433;Database=energytracker-db;Authentication=Active Directory Default;TrustServerCertificate=False;Encrypt=True;",

    "AzureStorageAccountName": "<storage account name — from deploy.sh output>",

    "KeyVaultUri": "https://<keyvault-name>.vault.azure.net/",

    "AZURE_CLIENT_ID": ""
  }
}
